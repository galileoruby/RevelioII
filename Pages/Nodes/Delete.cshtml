@page
@model RevelioII.Pages.Nodes.DeleteModel
@{
    ViewData["Title"] = "Delete Node";
}

<h1>Delete Node</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Type</dt>
        <dd class="col-sm-10">@Model.GraphNode.Type</dd>

        <dt class="col-sm-2">Label</dt>
        <dd class="col-sm-10">@Model.GraphNode.Label</dd>

        <dt class="col-sm-2">Properties</dt>
        <dd class="col-sm-10">@Model.GraphNode.Properties</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="GraphNode.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>