@page
@model RevelioII.Pages.Relationships.DeleteModel
@{
    ViewData["Title"] = "Delete Relationship";
}

<h1>Delete Relationship</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Source Node</dt>
        <dd class="col-sm-9">[@Model.GraphRelationship.SourceNodeId] @Model.GraphRelationship.SourceNode?.Label</dd>

        <dt class="col-sm-3">Target Node</dt>
        <dd class="col-sm-9">[@Model.GraphRelationship.TargetNodeId] @Model.GraphRelationship.TargetNode?.Label</dd>

        <dt class="col-sm-3">Relation Type</dt>
        <dd class="col-sm-9">@Model.GraphRelationship.RelationType</dd>

        <dt class="col-sm-3">Properties</dt>
        <dd class="col-sm-9">@Model.GraphRelationship.Properties</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="GraphRelationship.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
